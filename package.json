{
  "name": "react-procedural-scroller",
  "version": "1.0.0",
  "description": "A virtualised scroller component for rendering infinite, procedurally generated data sets – ideal for use cases like endlessly scrollable timelines, dates, or number sequences.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc --noEmit && tsup",
    "format": "npx prettier . --write",
